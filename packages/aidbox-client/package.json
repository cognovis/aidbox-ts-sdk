{
	"name": "@health-samurai/aidbox-client",
	"version": "0.0.0-alpha.6",
	"description": "A client library for communicating with Aidbox",
	"author": "Health Samurai",
	"type": "module",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"default": "./dist/src/index.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && mkdir -p dist && swc src -d dist -D && tsc -b --force && echo success",
		"format": "biome format",
		"format:check": "biome format",
		"format:fix": "biome format --write",
		"lint": "biome check",
		"lint:check": "biome check",
		"lint:fix": "biome check --write",
		"tsc:check": "tsc -b --noEmit",
		"typecheck": "tsc -b --noEmit",
		"generate-types": "tsx scripts/generate-types.ts",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"doc": "typedoc"
	},
	"dependencies": {
		"@types/json-patch": "^0.0.33",
		"oauth4webapi": "^3.8.5",
		"yaml": "^2.8.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/HealthSamurai/aidbox-ts-sdk/tree/master/packages/aidbox-client#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/HealthSamurai/aidbox-ts-sdk",
		"directory": "packages/aidbox-client"
	},
	"devDependencies": {
		"@atomic-ehr/codegen": "^0.0.8",
		"@types/node": "^25.4.0",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.17",
		"typescript": "~5.9.3",
		"vitest": "^4.0.18"
	}
}
